{
  "name": "chess-core",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal/moveTables.d.ts",
      "import": "./dist/esm/internal/moveTables.js",
      "require": "./dist/internal/moveTables.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.2.2"
  }
}
